# Copy to `.env` and adjust. See README → Configuration.
#
# Logging (Winston → console): info = summaries; debug = every HTTP + verbose lines.
# Scopes: main, migrate, spoolman, bambuddy.
# LOG_LEVEL=info
# LOG_LEVEL=debug

SPOOLMAN_URL=http://your-host:7912

# Optional: HTTP Basic auth if Spoolman is behind it
# SPOOLMAN_BASIC_USER=
# SPOOLMAN_BASIC_PASS=

# Bambuddy (node main.js --sync --system bambuddy). Base = origin only, no /api/v1 suffix.
# BAMBUDDY_URL=http://your-host:8000
# API key needs inventory:* (spools, /inventory/catalog, /inventory/colors) AND
# filaments:* for /api/v1/filament-catalog (Settings → API Keys).
# BAMBUDDY_API_KEY=
